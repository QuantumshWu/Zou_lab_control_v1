\IfFontExistsTF{TeX Gyre Heros}{\setsansfont{TeX Gyre Heros}}{\setsansfont{Latin Modern Sans}}
\IfFontExistsTF{JetBrains Mono}{\setmonofont{JetBrains Mono}[Scale=0.88]}{\IfFontExistsTF{Cascadia Mono}{\setmonofont{Cascadia Mono}[Scale=0.88]}{\setmonofont{Latin Modern Mono}[Scale=0.88]}}
\IfFontExistsTF{Microsoft YaHei}{\setCJKmainfont{Microsoft YaHei}}{\IfFontExistsTF{SimSun}{\setCJKmainfont{SimSun}}{\setCJKmainfont{FandolSong-Regular}}}
\IfFontExistsTF{Microsoft YaHei}{\setCJKsansfont{Microsoft YaHei}}{\IfFontExistsTF{SimHei}{\setCJKsansfont{SimHei}}{\setCJKsansfont{FandolHei-Regular}}}
\IfFontExistsTF{Microsoft YaHei Mono}{\setCJKmonofont{Microsoft YaHei Mono}}{\IfFontExistsTF{Microsoft YaHei}{\setCJKmonofont{Microsoft YaHei}}{\setCJKmonofont{FandolHei-Regular}}}

\definecolor{StarkTeal}{HTML}{1F7A7A}
\definecolor{StarkFocus}{HTML}{145F5F}
\definecolor{StarkBlue}{HTML}{385A8A}
\definecolor{StarkGray}{HTML}{6C737A}
\definecolor{StarkPale}{HTML}{E8ECEF}
\definecolor{StarkTint}{HTML}{E0F0EF}
\definecolor{StarkGold}{HTML}{B8872B}
\definecolor{StarkCodeBack}{HTML}{F6F7F8}
\definecolor{StarkShellBack}{HTML}{20272B}
\definecolor{StarkShellText}{HTML}{EEF3F3}

\hypersetup{
  colorlinks=true,
  linkcolor=StarkBlue,
  citecolor=StarkTeal,
  urlcolor=StarkTeal,
  pdfborder={0 0 0}
}

\setlength{\parindent}{1.7em}
\setlength{\parskip}{0.25em}
\setlength{\marginparpush}{1.05\baselineskip}
\setlength{\emergencystretch}{2em}
\setlength{\headheight}{22pt}
\setlength{\abovedisplayskip}{0.55em plus 0.2em minus 0.15em}
\setlength{\belowdisplayskip}{0.55em plus 0.2em minus 0.15em}
\setlength{\abovedisplayshortskip}{0.35em plus 0.15em minus 0.1em}
\setlength{\belowdisplayshortskip}{0.45em plus 0.15em minus 0.1em}
\linespread{1.08}
\setcounter{secnumdepth}{2}
\setcounter{tocdepth}{2}
\setlist{itemsep=0.2em,topsep=0.3em}

\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0.35pt}
\renewcommand{\headrule}{\hbox to\headwidth{\color{StarkTeal}\leaders\hrule height \headrulewidth\hfill}}
\fancyhead[L]{\small\nouppercase{\rightmark}}
\fancyhead[R]{\small\thepage}

\titleformat{\chapter}[display]
  {\normalfont\centering}
  {\fontsize{54}{54}\selectfont\color{StarkPale}\thechapter}
  {0.3ex}
  {\Huge\bfseries\sffamily}
\titlespacing*{\chapter}{0pt}{26mm}{18mm}

\titleformat{\section}
  {\Large\bfseries\sffamily}
  {\color{StarkTeal}\thesection}
  {0.7em}
  {}
\titlespacing*{\section}{0pt}{2.0ex plus 0.5ex minus 0.2ex}{1.0ex}

\titleformat{\subsection}
  {\large\bfseries\sffamily}
  {\color{StarkBlue}\thesubsection}
  {0.7em}
  {}

\titlecontents{chapter}
  [0pt]
  {\addvspace{0.7em}\bfseries\color{StarkBlue}}
  {\contentslabel{2.4em}}
  {}
  {\titlerule*[0.7pc]{.}\contentspage}
\titlecontents{section}
  [2.4em]
  {\small}
  {\contentslabel{2.8em}}
  {}
  {\titlerule*[0.7pc]{.}\contentspage}

\newcommand{\zlctitlepage}[4]{%
  \begin{titlepage}
    \thispagestyle{empty}
    \vspace*{0.24\textheight}
    \begin{center}
      {\Huge\bfseries\sffamily #1\par}
      \vspace{1.0em}
      {\color{StarkTeal}\rule{0.58\textwidth}{0.6pt}\par}
      \vspace{0.7em}
      {\Large #2\par}
      \vspace{0.7em}
      {\color{StarkTeal}\rule{0.58\textwidth}{0.6pt}\par}
      \vfill
      {\Large #3\par}
      \vspace{0.8em}
      {\large #4\par}
    \end{center}
  \end{titlepage}
}
\let\starktitlepage\zlctitlepage

% Side-note system inherited from the Stark notes template.
\newcounter{starksidenote}
\newcommand{\starknotebox}[1]{\fontsize{6.8}{7.6}\selectfont\color{StarkGray}\RaggedRight\hspace{0pt}\setlength{\parskip}{0.12em}\setlength{\emergencystretch}{3em}#1}
\newcommand{\starksidepar}[1]{\marginpar{\vspace{0pt}\starknotebox{#1}\par\vspace{0.15\baselineskip}}}
\newcommand{\sidemark}[1]{\ifmmode{}^{\text{\color{StarkTeal}\scriptsize\sffamily #1}}\else\textsuperscript{\color{StarkTeal}\footnotesize\sffamily #1}\fi}
\newcommand{\snote}[1]{\refstepcounter{starksidenote}\sidemark{S\thestarksidenote}\starksidepar{\textcolor{StarkTeal}{S\thestarksidenote}.~#1}}
\newcommand{\snotemanual}[2]{\sidemark{#1}\starksidepar{\textcolor{StarkTeal}{#1}.~#2}}
\newcommand{\snotemark}{\refstepcounter{starksidenote}\sidemark{S\thestarksidenote}}
\newcommand{\snotetext}[1]{\starksidepar{\textcolor{StarkTeal}{S\thestarksidenote}.~#1}}
\newcommand{\snotemarkmanual}[1]{\sidemark{#1}}
\newcommand{\snotetextmanual}[2]{\starksidepar{\textcolor{StarkTeal}{#1}.~#2}}
\newcommand{\markedmargin}[2]{\snotemanual{#1}{#2}}
\newcommand{\markedsubmargin}[2]{\snotemarkmanual{#1}\ignorespacesafterend}
\newcommand{\starksidenote}[1]{\snote{#1}}

\newcommand{\tfocus}[1]{\textcolor{StarkFocus}{\bfseries #1}}
\newcommand{\starkfocusbox}[1]{%
  \begingroup
  \setlength{\fboxsep}{3pt}%
  \colorbox{StarkTint}{%
    $\displaystyle\color{StarkFocus}%
    \vphantom{\dfrac{1}{1}}%
    #1$%
  }%
  \endgroup
}
\newcommand{\starkeqref}[1]{Eq.~\eqref{#1}}
\newcommand{\starksecref}[1]{Sec.~\ref{#1}}

\newcommand{\diff}{\mathop{}\!\mathrm{d}}
\newcommand{\ii}{\mathrm{i}}
\newcommand{\ee}{\mathrm{e}}
\newcommand{\order}{\mathcal{O}}
\newcommand{\bra}[1]{\left\langle #1\right|}
\newcommand{\ket}[1]{\left|#1\right\rangle }
\newcommand{\state}[3]{\left\langle #1\middle|#2\middle|#3\right\rangle }
\newcommand{\reducedstate}[3]{\left\langle #1\middle\Vert#2\middle\Vert#3\right\rangle }
\newcommand{\operator}[2]{\left|#1\middle\rangle\middle\langle#2\right|}

% Frontend/software note utilities.
\newcommand{\pyapi}[1]{\textcolor{StarkBlue}{\texttt{\detokenize{#1}}}}
\newcommand{\filepath}[1]{\textcolor{StarkFocus}{\texttt{\detokenize{#1}}}}
\newcommand{\cmdinline}[1]{\textcolor{StarkTeal}{\texttt{\detokenize{#1}}}}

\newtcbox{\zinlinecode}{on line,boxrule=0pt,arc=1pt,colback=StarkCodeBack,colframe=StarkCodeBack,left=1pt,right=1pt,top=1pt,bottom=1pt}

\DefineVerbatimEnvironment{zlcverbatim}{Verbatim}{
  breaklines=true,
  breakanywhere=true,
  fontsize=\small
}

\newenvironment{codeblock}[1][Python]{%
  \VerbatimEnvironment
  \begin{tcolorbox}[
    enhanced,
    breakable,
    colback=StarkCodeBack,
    colframe=StarkPale,
    boxrule=0.4pt,
    arc=1pt,
    left=2mm,right=2mm,top=1mm,bottom=1mm,
    title={#1},
    coltitle=StarkBlue,
    fonttitle=\sffamily\bfseries\small
  ]
  \begin{zlcverbatim}
}{%
  \end{zlcverbatim}
  \end{tcolorbox}
}

\newenvironment{shellblock}{%
  \VerbatimEnvironment
  \begin{tcolorbox}[
    enhanced,
    breakable,
    colback=StarkShellBack,
    colframe=StarkTeal,
    boxrule=0.4pt,
    arc=1pt,
    left=2mm,right=2mm,top=1mm,bottom=1mm,
    title={Command line},
    coltitle=StarkShellText,
    fonttitle=\sffamily\bfseries\small
  ]
  \color{StarkShellText}
  \begin{zlcverbatim}
}{%
  \end{zlcverbatim}
  \end{tcolorbox}
}

\newenvironment{notebox}[1][Note]{%
  \begin{tcolorbox}[
    enhanced,
    breakable,
    colback=StarkTint,
    colframe=StarkTeal,
    boxrule=0.4pt,
    arc=1pt,
    left=2mm,right=2mm,top=1mm,bottom=1mm,
    title={#1},
    coltitle=StarkFocus,
    fonttitle=\sffamily\bfseries\small
  ]
}{%
  \end{tcolorbox}
}
